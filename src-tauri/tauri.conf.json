{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.cargo/src/tauri-utils/schema.json",
  "productName": "PDFoo",
  "version": "0.1.0",
  "identifier": "com.pdfoo.app",
  "build": {
    "beforeDevCommand": "concurrently -n vite,py \"vite\" \"venv/bin/uvicorn app.main:app --reload --port 8456\"",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDFoo",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pdfoo-server"
    ]
  }
}
